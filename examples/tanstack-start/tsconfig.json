{
  "include": ["src", "vite.config.ts"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "verbatimModuleSyntax": true,
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  }
}
